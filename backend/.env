# Configuración de Astren Backend
# =====================================

# Microsoft Graph API (para Microsoft To Do)
MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback

# Google Classroom API
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Configuración del servidor
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your_super_secret_key_change_this_in_production

# Base de datos (para versión futura)
DATABASE_URL=sqlite:///astren.db

# Configuración de CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080

# Configuración de logs
LOG_LEVEL=INFO

# Configuración de cache
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300

# Configuración de sesiones
SESSION_TIMEOUT=3600

# Configuración de iCloud CalDAV
ICLOUD_CALDAV_URL=https://caldav.icloud.com

# Límites de rate limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# Configuración de archivo uploads
MAX_CONTENT_LENGTH=16777216  # 16MB
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,gif,doc,docx

# Timezone
TIMEZONE=America/Mexico_City

# Configuración de email (para notificaciones futuras)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_USE_TLS=True